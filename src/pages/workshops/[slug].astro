---
import { render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TagList from '../../components/TagList.astro';
import { formatDate, getPublishedWorkshops } from '../../lib/content';
import { withBase } from '../../lib/url';

export async function getStaticPaths() {
  const entries = await getPublishedWorkshops();
  return entries.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'workshops'>;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.summary}>
  <article class="article container">
    <header class="article-header">
      <p class="eyebrow">Workshop Summary</p>
      <h1>{entry.data.title}</h1>
      <time datetime={entry.data.date.toISOString()}>{formatDate(entry.data.date)}</time>
      <p class="article-header__summary">{entry.data.summary}</p>
      <TagList tags={entry.data.tags} />
    </header>
    <div class="prose">
      <Content />
    </div>
    <a class="back-link" href={withBase('/workshops/')}>← Workshop一覧へ戻る</a>
  </article>
</BaseLayout>
