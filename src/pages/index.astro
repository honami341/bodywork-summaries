---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContentCard from '../components/ContentCard.astro';
import { getPublishedAdvice, getPublishedWorkshops } from '../lib/content';
import { withBase } from '../lib/url';

const workshops = await getPublishedWorkshops();
const advice = await getPublishedAdvice();
const latest = [
  ...workshops.map((entry) => ({ entry, kind: 'Workshop' as const, section: 'workshops' })),
  ...advice.map((entry) => ({ entry, kind: 'Advice' as const, section: 'advice' })),
]
  .sort((a, b) => b.entry.data.date.getTime() - a.entry.data.date.getTime())
  .slice(0, 6);
---

<BaseLayout>
  <section class="hero container">
    <p class="eyebrow">A quiet archive for bodywork</p>
    <h1>身体の動きを、<br />あとから読み返せる形に。</h1>
    <p class="hero__lead">身体の動きを理解するための、ワークショップとアドバイスの記録。</p>
  </section>

  <section class="container section" aria-labelledby="library-heading">
    <div class="section-heading">
      <p class="eyebrow">Library</p>
      <h2 id="library-heading">記録をひらく</h2>
    </div>
    <div class="gateway-grid">
      <a class="gateway-card" href={withBase('/workshops/')}>
        <span class="gateway-card__number">01</span>
        <h3>Workshop Summary</h3>
        <p>ワークショップや講座で扱った内容の記録。</p>
        <span class="text-link">一覧を見る →</span>
      </a>
      <a class="gateway-card" href={withBase('/advice/')}>
        <span class="gateway-card__number">02</span>
        <h3>Advice Summary</h3>
        <p>身体の使い方について共有した内容の記録。</p>
        <span class="text-link">一覧を見る →</span>
      </a>
    </div>
  </section>

  <section class="container section" aria-labelledby="latest-heading">
    <div class="section-heading">
      <p class="eyebrow">Recently added</p>
      <h2 id="latest-heading">最近の記録</h2>
    </div>
    <div class="card-list">
      {latest.map(({ entry, kind, section }) => (
        <ContentCard
          href={withBase(`/${section}/${entry.data.slug}/`)}
          kind={kind}
          title={entry.data.title}
          date={entry.data.date}
          summary={entry.data.summary}
          tags={entry.data.tags}
        />
      ))}
    </div>
  </section>
</BaseLayout>
